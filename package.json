{
  "name": "free-map",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc -b && vite build",
    "build:local": "vue-tsc -b && vite build --base ./ && node scripts/inline-local-build.mjs",
    "build:mac": "pnpm build:local && ditto -c -k --sequesterRsrc dist-local free-map-mac.zip",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@vueuse/core": "^13.4.0",
    "vue": "^3.5.16"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/tsconfig": "^0.9.1",
    "sass": "^1.100.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vue-tsc": "^2.2.10"
  },
  "packageManager": "pnpm@10.2.1+sha1.48adf39a4ab751eda7b73b99447d1f0b6d227e02"
}
